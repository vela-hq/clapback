# Copy to .env.local and fill in. Both are gitignored.

# Mixpanel project token (from Project Settings). Safe to expose to the browser.
# Powers both analytics and waitlist storage (server-side People profiles).
NEXT_PUBLIC_MIXPANEL_TOKEN=

# --- Live roast: Cooper on Cloud Run -----------------------------------------
# Leave COOPER_URL empty for local work: /api/roast then replays the canned
# reddit findings, so the UI runs with no GCP setup at all. That fallback is
# refused in production (serving reddit's roast for someone else's site would
# be lying to a user), so a deployed build MUST set these.

# The private Cloud Run service. No trailing slash.
COOPER_URL=

# Shared secret Cooper requires in the X-Cooper-Key header — the second lock
# behind Cloud Run IAM. Read it from Secret Manager:
#   gcloud secrets versions access latest --secret=cooper-shared-key
COOPER_KEY=

# How we prove identity to the *private* Cloud Run service. Two ways:
#
#  1. Leave this empty and use Application Default Credentials — preferred
#     locally (`gcloud auth application-default login`), and the path Workload
#     Identity Federation takes in production. Nothing long-lived on disk.
#  2. Set it to a service-account key, raw JSON or base64 (base64 survives
#     dashboard env vars, which mangle the private key's newlines). This is what
#     Vercel uses today. It is a STANDING credential: whoever holds it can make
#     Cooper spend money until the key is revoked.
#
#   gcloud iam service-accounts keys create key.json \
#     --iam-account=clapback-roast@clapback-502511.iam.gserviceaccount.com
#   base64 -w0 key.json
GCP_SERVICE_ACCOUNT_KEY=
