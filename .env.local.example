# Copy to .env.local and fill in. Both are gitignored.

# The Google Apps Script Web App URL (ends in /exec). See SETUP-sheets.md.
SHEETS_WEBHOOK_URL=

# Optional: a random string you also paste into the Apps Script, so only your
# API route can write to the sheet. Leave blank to skip the check.
SHEETS_WEBHOOK_SECRET=

# Mixpanel project token (from Project Settings). Safe to expose to the browser.
NEXT_PUBLIC_MIXPANEL_TOKEN=
